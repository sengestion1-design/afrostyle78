Options -MultiViews

# Block direct access to sensitive directories
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /
RewriteRule ^config/ - [F,L]
RewriteRule ^includes/ - [F,L]
RewriteRule ^vendor/ - [F,L]
</IfModule>

# Block access to sensitive file types
<FilesMatch "\.(env|log|sql|bak|sh)$">
    Require all denied
</FilesMatch>

# Rediriger les accès directs .php vers URL propre (hors admin/)
# UNIQUEMENT sur les requêtes GET : une redirection 301 sur un POST
# perd le corps de la requête (casse l'ajout au panier, les webhooks, le checkout AJAX).
# On exclut aussi explicitement les endpoints techniques (AJAX / webhooks).
RewriteCond %{REQUEST_METHOD} =GET
RewriteCond %{THE_REQUEST} \s/(?!admin/)([^.]+)\.php[\s?] [NC]
RewriteCond %1 !^(cart-action|paydunya-webhook|wave-webhook|paydunya-success|wave-success|stripe-success)$ [NC]
RewriteRule ^ /%1 [R=301,L]

# Réécrire les URLs propres vers .php (liste explicite)
RewriteRule ^boutique$ boutique.php [NC,L]
RewriteRule ^produit$ produit.php [NC,L]
RewriteRule ^panier$ panier.php [NC,L]
RewriteRule ^commande$ commande.php [NC,L]
RewriteRule ^confirmation$ confirmation.php [NC,L]
RewriteRule ^suivi$ suivi.php [NC,L]
RewriteRule ^sur-mesure$ sur-mesure.php [NC,L]
RewriteRule ^login$ login.php [NC,L]
RewriteRule ^logout$ logout.php [NC,L]
RewriteRule ^register$ register.php [NC,L]
RewriteRule ^compte$ compte.php [NC,L]
RewriteRule ^stripe-checkout$ stripe-checkout.php [NC,L]
RewriteRule ^stripe-success$ stripe-success.php [NC,L]
RewriteRule ^paydunya-checkout$ paydunya-checkout.php [NC,L]
RewriteRule ^paydunya-success$ paydunya-success.php [NC,L]
RewriteRule ^paydunya-webhook$ paydunya-webhook.php [NC,L]
RewriteRule ^cart-action$ cart-action.php [NC,L]
RewriteRule ^wave-checkout$ wave-checkout.php [NC,L]
RewriteRule ^wave-success$ wave-success.php [NC,L]
RewriteRule ^wave-webhook$ wave-webhook.php [NC,L]
RewriteRule ^paydunya-webhook$ paydunya-webhook.php [NC,L]
RewriteRule ^mot-de-passe-oublie$ mot-de-passe-oublie.php [NC,L]
RewriteRule ^politique-confidentialite$ politique-confidentialite.php [NC,L]
RewriteRule ^guide-des-tailles$ guide-des-tailles.php [NC,L]
RewriteRule ^cgv$ cgv.php [NC,L]
RewriteRule ^mentions-legales$ mentions-legales.php [NC,L]

# Page 404 personnalisée
ErrorDocument 404 /404.php
